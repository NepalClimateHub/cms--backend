// Add this enum for user types
enum UserType {
  ADMIN
  ORGANIZATION
  INDIVIDUAL
}

enum BlogStatus {
  DRAFT
  UNDER_REVIEW
  PUBLISHED
  REJECTED
}

model User {
  id                String    @id() @default(cuid())
  fullName          String
  email             String    @unique() @db.VarChar(254)
  password          String
  isAccountVerified Boolean   @default(false)
  isSuperAdmin      Boolean   @default(false)
  profession        String?
  expertise         String?
  bio               String?
  dateOfBirth       DateTime? @db.Timestamptz(6)
  dateOfJoin        DateTime? @db.Timestamptz(6)
  gender            String?
  phoneCountryCode  String?
  phoneNumber       String?
  profilePhotoUrl   String?
  profilePhotoId    String?

  address   Address? @relation(fields: [addressId], references: [id])
  addressId String?

  socials   Json?
  socialsId String?

  gallery Gallery[]
  tags    Tags[]
  blogs   Blog[]

  resetPasswordToken              String?
  resetPasswordExpires            DateTime?
  accountVerificationToken        String?
  accountVerificationTokenExpires DateTime?

  userType UserType @default(INDIVIDUAL)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}

model Organizations {
  id               String  @id() @default(cuid())
  name             String
  description      String
  email            String
  phoneCountryCode String?
  phoneNumber      String?

  tags                Tags[]
  organizationGallery Gallery[]

  address   Address? @relation(fields: [addressId], references: [id])
  addressId String?

  socials   Json?
  socialsId String?

  bannerImageId  String?
  bannerImageUrl String?

  logoImageUrl String
  logoImageId  String?

  isDraft   Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Events {
  id           String  @id() @default(cuid())
  title        String
  organizer    String  @map("organizer")
  description  String
  // location is like venue
  location     String?
  locationType String
  type         String
  format       String
  website      String?

  startDate            DateTime?
  registrationDeadline DateTime?
  registrationLink     String?
  contactEmail         String?
  status               String?
  cost                 String?

  tags         Tags[]
  eventGallery Gallery[]

  address   Address? @relation(fields: [addressId], references: [id])
  addressId String?

  socials   Json?
  socialsId String?

  bannerImageId  String?
  bannerImageUrl String?

  contributedBy String

  isDraft   Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Opportunity {
  id                  String    @id() @default(cuid())
  title               String
  organizer           String    @map("organizer")
  description         String
  // location is like venue
  location            String
  locationType        String
  type                String
  format              String
  applicationDeadline DateTime?
  duration            String?
  contactEmail        String?
  status              String?
  cost                String?
  websiteUrl          String?

  tags Tags[]

  address   Address? @relation(fields: [addressId], references: [id])
  addressId String?

  socials Json?

  bannerImageId  String?
  bannerImageUrl String?

  contributedBy String

  isDraft   Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model News {
  id            String   @id() @default(cuid())
  title         String
  source        String
  mode          String
  publishedDate DateTime
  publishedYear DateTime
  newsLink      String

  tags Tags[]

  contributedBy String

  isDraft   Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Blog {
  id              String     @id() @default(cuid())
  title           String
  content         String
  excerpt         String?
  author          String
  category        String
  readingTime     String?
  publishedDate   DateTime?
  isDraft         Boolean    @default(true)
  isFeatured      Boolean    @default(false)
  approvedByAdmin Boolean    @default(false)
  status          BlogStatus @default(DRAFT)
  bannerImageUrl  String?
  bannerImageId   String?

  tags Tags[]

  authorId   String?
  authorUser User?   @relation(fields: [authorId], references: [id])

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Address {
  id       String  @id() @default(cuid())
  street   String?
  country  String?
  city     String?
  state    String?
  postcode String?

  user         User[]
  event        Events[]
  opportunity  Opportunity[]
  organization Organizations[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Tags {
  id                String  @id() @default(cuid())
  tag               String
  isUserTag         Boolean @default(false)
  isOrganizationTag Boolean @default(false)
  isEventTag        Boolean @default(false)
  isNewsTag         Boolean @default(false)
  isOpportunityTag  Boolean @default(false)
  isBlogTag         Boolean @default(false)

  user         User[]
  event        Events[]
  news         News[]
  blog         Blog[]
  organization Organizations[]
  opportunity  Opportunity[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Gallery {
  id        String  @id() @default(cuid())
  sourceId  String?
  publicUrl String

  user         User[]
  events       Events[]
  organization Organizations[]

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model SubscribedEmailUser {
  id        String    @id() @default(cuid())
  email     String    @unique() @db.VarChar(254)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  deletedAt DateTime?
}

// ===== NCH Climate Assistant Schemas =====

model NchChatSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.VarChar(255)
  title     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages NchChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model NchChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String   @db.VarChar(50)
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  session NchChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model NchDocument {
  id         String   @id @default(uuid()) @db.Uuid
  title      String   @db.VarChar(300)
  sourceUrl  String?  @map("source_url")
  totalPages Int?     @map("total_pages")
  mediaType  String   @default("text/pdf") @map("media_type") @db.VarChar(40)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  chunks NchChunk[]

  @@index([title])
  @@map("documents")
}

model NchChunk {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  chunkIndex Int      @map("chunk_index")
  pageStart  Int?     @map("page_start")
  pageEnd    Int?     @map("page_end")
  text       String
  vector     Json
  meta       Json     @default("{}")
  collection String   @default("main") @db.VarChar(64)
  embedModel String   @default("intfloat/multilingual-e5-base") @map("embed_model") @db.VarChar(120)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document      NchDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  citations     NchCitation[]
  retrievalHits NchRetrievalHit[]

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([collection])
  @@map("chunks")
}

model NchQuery {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  text        String
  language    String?  @db.VarChar(10)
  routedModel String   @map("routed_model") @db.VarChar(80)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  answers    NchAnswer[]
  retrievals NchRetrieval[]

  @@index([userId])
  @@map("queries")
}

model NchRetrieval {
  id        String   @id @default(uuid()) @db.Uuid
  queryId   String   @map("query_id") @db.Uuid
  topK      Int      @default(10) @map("top_k")
  filters   Json     @default("{}")
  latencyMs Int      @map("latency_ms")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  query NchQuery          @relation(fields: [queryId], references: [id], onDelete: Cascade)
  hits  NchRetrievalHit[]

  @@index([queryId])
  @@map("retrievals")
}

model NchRetrievalHit {
  id          String @id @default(uuid()) @db.Uuid
  retrievalId String @map("retrieval_id") @db.Uuid
  rank        Int
  chunkId     String @map("chunk_id") @db.Uuid
  score       Float

  retrieval NchRetrieval @relation(fields: [retrievalId], references: [id], onDelete: Cascade)
  chunk     NchChunk     @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([retrievalId])
  @@index([chunkId])
  @@map("retrieval_hits")
}

model NchAnswer {
  id        String   @id @default(uuid()) @db.Uuid
  queryId   String   @map("query_id") @db.Uuid
  model     String   @db.VarChar(80)
  answerEn  String   @map("answer_en")
  answerNe  String?  @map("answer_ne")
  raw       Json?
  tokensIn  Int      @map("tokens_in")
  tokensOut Int      @map("tokens_out")
  latencyMs Int      @map("latency_ms")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  query     NchQuery      @relation(fields: [queryId], references: [id], onDelete: Cascade)
  citations NchCitation[]

  @@index([queryId])
  @@map("answers")
}

model NchCitation {
  id       String  @id @default(uuid()) @db.Uuid
  answerId String  @map("answer_id") @db.Uuid
  chunkId  String  @map("chunk_id") @db.Uuid
  title    String  @db.VarChar(300)
  page     String? @db.VarChar(40)
  url      String?

  answer NchAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  chunk  NchChunk  @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([answerId])
  @@map("citations")
}
